// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_wrap_guides": true,
  "wrap_guides": [80],
  "scrollbar": {
    "show": "never",
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
  },
  "hover_popover_delay": 500,
  "icon_theme": "VSCode Icons for Zed (Dark)",
  "project_panel": {
    "dock": "right",
  },
  "use_system_window_tabs": true,
  "title_bar": {
    "show_menus": true,
    "show_branch_icon": true,
  },
  "inlay_hints": {
    "enabled": false,
  },
  "vim": {
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "toolbar": {
    "code_actions": false,
  },
  "relative_line_numbers": "enabled",
  "show_signature_help_after_edits": false,
  "sticky_scroll": {
    "enabled": true,
  },
  "auto_signature_help": false,
  "which_key": {
    "enabled": true,
  },
  "rounded_selection": true,
  "preview_tabs": {
    "enable_preview_from_file_finder": true,
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "buffer_font_family": ".ZedMono",
  "buffer_font_features": {
    "calt": false,
  },
  "agent": {
    "show_turn_stats": true,
    "enable_feedback": false,
    "tool_permissions": {
      "default": "allow",
      "tools": {},
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2.5",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
      "favorite_models": ["opencode/kimi-k2.5"],
    },
    "gemini": {
      "type": "registry",
    },
    "cursor": {
      "type": "registry",
    },
    "amp-acp": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light",
    "dark": "Zed Legacy: Rosé Pine",
  },
}
